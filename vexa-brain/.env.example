# Vexa Brain — FastAPI AI Engine
# Copy this to .env and fill in your values

GROQ_API_KEY=gsk_your_groq_api_key_here
MONGODB_URI=mongodb://localhost:27017/observeai
MONGODB_DB_NAME=observeai

# LLM config
LLM_MODEL=llama3-70b-8192    # or mixtral-8x7b-32768
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
