# Vexa Brain — Production Environment Variables
# Copy this to .env and fill in your values

# ── Required ──
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── MongoDB (use Atlas for cloud deployment) ──
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/observeai?retryWrites=true&w=majority
MONGODB_DB_NAME=observeai

# ── LLM Config ──
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEBUG=false
